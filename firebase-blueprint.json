{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and wallet balances",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "balanceMYR": { "type": "number", "description": "Balance in Malaysian Ringgit" },
        "balanceBTC": { "type": "number", "description": "Balance in Bitcoin" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation time" }
      },
      "required": ["uid", "email", "balanceMYR", "balanceBTC"]
    },
    "Card": {
      "title": "Card",
      "description": "Linked credit/debit/TnG cards",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["visa", "mastercard", "tng"] },
        "last4": { "type": "string" },
        "expiry": { "type": "string" },
        "cardholderName": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "last4", "expiry", "cardholderName"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Wallet transaction record",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Owner of the transaction" },
        "type": { "type": "string", "enum": ["transfer", "swap", "deposit", "withdraw", "trade"], "description": "Type of transaction" },
        "subType": { "type": "string", "description": "Specific destination" },
        "amount": { "type": "number", "description": "Amount in source currency" },
        "currency": { "type": "string", "enum": ["MYR", "BTC", "USD", "EUR", "GBP"], "description": "Currency of the amount" },
        "targetAmount": { "type": "number" },
        "targetCurrency": { "type": "string" },
        "destination": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "amount", "currency", "status", "timestamp"]
    },
    "ForexTrade": {
      "title": "ForexTrade",
      "description": "Forex trading positions",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "pair": { "type": "string" },
        "type": { "type": "string", "enum": ["buy", "sell"] },
        "entryPrice": { "type": "number" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["open", "closed"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "closedAt": { "type": "string", "format": "date-time" },
        "profit": { "type": "number" }
      },
      "required": ["userId", "pair", "type", "entryPrice", "amount", "status", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/cards/{cardId}": {
      "schema": "Card",
      "description": "User linked cards"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Global transaction logs"
    },
    "/forex_trades/{tradeId}": {
      "schema": "ForexTrade",
      "description": "Forex trading history"
    }
  }
}
